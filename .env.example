# Comma-separated public listing/calendar pages to crawl.
LUMA_TARGET_URLS=https://luma.com/nyc

# Polite crawling defaults.
REQUEST_DELAY_SECONDS=2.0
MAX_EVENTS_PER_SOURCE=
SCROLL_ROUNDS=40
NO_NEW_URL_ROUNDS=5
HEADLESS=true
EXPORT_DIR=exports

# Optional Supabase storage. Use the service role key only in GitHub Actions secrets or local .env files.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional Google Sheets export.
GOOGLE_SHEET_ID=
GOOGLE_CREDENTIALS_JSON=
GOOGLE_CREDENTIALS_B64=
SHEET_WRITE_MODE=replace
